#!/usr/bin/env bash
# ghpr — Commit, push, and open a GitHub pull request from the terminal.
#
# Usage:
#   ghpr [options] [files...]
#   ghpr                        # Interactive mode
#   ghpr-feat "description"     # Quick feature commit
#   ghpr-fix "description"      # Quick fix commit
#
# Options:
#   -H, --head <branch>     Head branch (source of changes). Default: current branch
#   -b, --base <branch>     Base branch (PR target).         Default: origin default branch (or current branch)
#   -m, --message <msg>     Commit message (required when there are changes to commit)
#   -d, --draft             Create PR as a draft
#       --no-pr             Commit and push only; skip PR creation
#       --dry-run           Show what would happen without making changes
#       --json              Output results in JSON format
#       --preview           Show diff preview before committing
#       --suggest           Suggest commit message based on changes
#       --agent             Agent mode: output JSON schema for LLM interaction
#       --status            Show health report (uncommitted changes, branch status)
#   -v, --version           Print ghpr version
#   -h, --help              Show this help message
#
# Positional args:
#   files...                Files to stage. Omit to stage everything (git add -A)
#
# Examples:
#   ghpr -m "feat: improve search"
#   ghpr --head qa --base main -m "feat: release candidate"
#   ghpr --head feature/auth -m "feat: login flow" src/auth.js
#   ghpr -m "fix: typo" --no-pr
#   ghpr --head qa -m "chore: config update" --draft

set -euo pipefail

GHPR_VERSION="__GHPR_VERSION__"
if [[ "$GHPR_VERSION" == "__GHPR_VERSION__" ]]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "$SCRIPT_DIR/../VERSION" ]]; then
    GHPR_VERSION="$(<"$SCRIPT_DIR/../VERSION")"
  else
    GHPR_VERSION="dev"
  fi
fi

# ─── Helpers ──────────────────────────────────────────────────────────────────

die()   { echo "❌ ghpr: $*" >&2; exit 1; }
info()  { echo "ℹ  $*"; }
ok()    { echo "✅ $*"; }

output_json() {
  local success="$1"
  local message="${2:-}"
  
  printf '{"success":%s,"version":"%s","message":"%s"' "$success" "$GHPR_VERSION" "${message//\"/\\\"}"
  
  # Add commit info if available
  if [[ -n "${COMMIT_HASH:-}" ]]; then
    printf ',"commit":{"hash":"%s","message":"%s"}' "$COMMIT_HASH" "${COMMIT_MSG//\"/\\\"}"
  fi
  
  # Add push info if available
  if [[ -n "${PUSHED_BRANCH:-}" ]]; then
    printf ',"push":{"branch":"%s","remote":"origin"}' "$PUSHED_BRANCH"
  fi
  
  # Add PR info if available
  if [[ -n "${PR_CREATED:-}" ]]; then
    printf ',"pr":{"created":true,"head":"%s","base":"%s"}' "$HEAD_BRANCH" "$BASE_BRANCH"
  fi
  
  printf '}\n'
}

suppress_output() {
  if [[ "$JSON_OUTPUT" == true ]]; then
    # Suppress human-readable output when using JSON mode
    return 0
  fi
  return 1
}

load_config() {
  CONFIG_FILE="${HOME}/.ghprrc"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    CONFIG_FILE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/.ghprrc"
  fi
  
  if [[ -f "$CONFIG_FILE" ]]; then
    # Parse JSON config (simple approach for common keys)
    DEFAULT_BASE=$(grep -o '"default_base"[[:space:]]*:[[:space:]]*"[^"]*"' "$CONFIG_FILE" | cut -d'"' -f4 || echo "")
    INTERACTIVE_MODE=$(grep -o '"interactive_mode"[[:space:]]*:[[:space:]]*true' "$CONFIG_FILE" | grep -q true && echo true || echo false)
  fi
}

suggest_commit_message() {
  # Generate a commit message suggestion based on git diff
  local added=$(git diff --cached --stat | wc -l)
  local deleted=$(git diff --cached --stat | tail -1 | awk '{print $NF}' | tr 'd' ' ')
  
  if [[ $added -gt 5 ]]; then
    echo "feat: add new features and updates"
  elif git diff --cached | grep -q "fix\|bug"; then
    echo "fix: resolve issues and bugs"
  elif git diff --cached | grep -q "README\|\.md\|docs"; then
    echo "docs: update documentation"
  else
    echo "chore: update dependencies and configuration"
  fi
}

show_diff_preview() {
  if [[ $(git diff --cached --stat | wc -l) -eq 0 ]]; then
    info "No staged changes to preview."
    return 0
  fi
  
  echo ""
  echo "📝 Preview of changes:"
  echo "────────────────────────────────────────"
  git diff --cached --stat
  echo "────────────────────────────────────────"
  echo ""
}

interactive_prompt() {
  # Interactive mode for users who just run 'ghpr' with no args
  echo ""
  echo "🚀 ghpr interactive mode"
  echo ""
  
  show_diff_preview
  
  # Get commit type
  echo "Commit type:"
  echo "  1) feat (feature)   2) fix (bug fix)      3) docs (documentation)"
  echo "  4) style (format)   5) refactor (code)    6) test (testing)"
  echo "  7) chore (other)    8) custom"
  read -r -p "Select [1-8]: " type_choice
  
  case $type_choice in
    1) TYPE="feat" ;;
    2) TYPE="fix" ;;
    3) TYPE="docs" ;;
    4) TYPE="style" ;;
    5) TYPE="refactor" ;;
    6) TYPE="test" ;;
    7) TYPE="chore" ;;
    8) read -r -p "Enter type: " TYPE ;;
    *) TYPE="chore" ;;
  esac
  
  # Get description
  read -r -p "Description: " DESC
  COMMIT_MSG="$TYPE: $DESC"
  
  # Confirm
  echo ""
  echo "Commit: $COMMIT_MSG"
  read -r -p "Proceed? [y/N]: " confirm
  
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo "Cancelled."
    exit 0
  fi
}

prompt_for_pr_body() {
  # Ask user for PR description
  echo ""
  read -r -p "PR Description (press Enter to skip): " body_input
  PR_BODY="$body_input"
}

agent_mode_prompt() {
  # Output a JSON schema for LLM interaction
  local current_branch current_status
  current_branch=$(git rev-parse --abbrev-ref HEAD)
  current_status=$(git status --short | wc -l)
  
  cat <<EOF
{
  "mode": "agent",
  "version": "$GHPR_VERSION",
  "context": {
    "current_branch": "$current_branch",
    "uncommitted_changes": $current_status,
    "has_staged_changes": $(git diff --cached --quiet && echo false || echo true)
  },
  "prompt": "What would you like to commit?",
  "schema": {
    "type": "object",
    "required": ["message"],
    "properties": {
      "message": {
        "type": "string",
        "description": "Commit message (or 'type: description' for conventional commits)"
      },
      "files": {
        "type": "array",
        "items": {"type": "string"},
        "description": "Files to stage (optional; defaults to all)"
      },
      "head_branch": {
        "type": "string",
        "description": "Head branch for PR (optional)"
      },
      "base_branch": {
        "type": "string",
        "description": "Base branch for PR (optional)"
      },
      "create_pr": {
        "type": "boolean",
        "description": "Create PR? (default: true)"
      }
    }
  }
}
EOF
  exit 0
}

status_report() {
  # Show health report of the repository
  local uncommitted unpushed branch
  uncommitted=$(git status --short | wc -l)
  unpushed=$(git log origin/main..HEAD 2>/dev/null | wc -l || echo 0)
  branch=$(git rev-parse --abbrev-ref HEAD)
  
  if [[ "$JSON_OUTPUT" == true ]]; then
    cat <<EOF
{
  "success": true,
  "branch": "$branch",
  "uncommitted_changes": $uncommitted,
  "unpushed_commits": $unpushed,
  "remote_tracking": "$(git rev-parse @{u} 2>/dev/null | cut -c1-7 || echo 'none')",
  "status": "$([ $uncommitted -gt 0 ] && echo 'has-changes' || echo 'clean')",
  "suggested_next_action": "$([ $uncommitted -gt 0 ] && echo 'stage-and-commit' || echo 'nothing-to-do')"
}
EOF
  else
    echo ""
    echo "📊 Repository Status"
    echo "────────────────────"
    echo "   Branch: $branch"
    echo "   Uncommitted: $uncommitted file(s)"
    echo "   Unpushed: $unpushed commit(s)"
    if [[ $uncommitted -gt 0 ]]; then
      echo "   → Run ghpr to commit changes"
    else
      echo "   → Working tree is clean"
    fi
    echo ""
  fi
  exit 0
}

usage() {
  # Print every leading comment line (strip the leading '# ' or lone '#')
  while IFS= read -r line; do
    [[ "$line" == \#!* ]] && continue         # skip shebang
    [[ "$line" == \#* ]]  || break            # stop at first non-comment line
    # strip leading '# ' or lone '#'
    printf '%s\n' "${line#\#}"  | sed 's/^ //'
  done < "$0"
  exit 0
}

print_version() {
  echo "ghpr $GHPR_VERSION"
  exit 0
}

check_for_updates() {
  # Only check if we're not in 'dev' mode
  [[ "$GHPR_VERSION" == "dev" ]] && return 0
  
  # Try to fetch latest version from origin tags (non-blocking)
  local latest_version
  latest_version=$(git -C "$(git rev-parse --git-dir 2>/dev/null | xargs dirname)" describe --tags --abbrev=0 2>/dev/null | sed 's/^v//' || true)
  
  # Fall back to checking in parent directory if we can't find it from current repo
  if [[ -z "$latest_version" ]]; then
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    latest_version=$(cd "$script_dir" && git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//' || true)
  fi
  
  [[ -z "$latest_version" ]] && return 0
  
  # Compare versions: if latest > current, prompt user
  if [[ "$latest_version" != "$GHPR_VERSION" ]]; then
    if printf '%s\n' "$latest_version" "$GHPR_VERSION" | sort -V | head -1 | grep -q "$GHPR_VERSION" && [[ "$latest_version" != "$GHPR_VERSION" ]]; then
      echo ""
      echo "📦 A new version of ghpr is available: $latest_version (current: $GHPR_VERSION)"
      
      # Try to locate update.sh
      local update_script
      if [[ -x "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/update.sh" ]]; then
        update_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/update.sh"
      fi
      
      if [[ -n "${update_script:-}" ]]; then
        read -r -p "   Run 'ghpr-update' to upgrade? [y/N] " reply </dev/tty 2>/dev/null || return 0
        if [[ "$reply" =~ ^[Yy]$ ]]; then
          echo "→ Running update..."
          "$update_script"
          echo ""
          echo "✅ ghpr updated to $latest_version"
        fi
      else
        echo "   Run: ./update.sh"
        echo ""
      fi
    fi
  fi
}

require_cmd() {
  command -v "$1" &>/dev/null || die "Required command not found: $1. Please install it."
}

# ─── Display Logo ─────────────────────────────────────────────────────────────

show_logo_on_first_run() {
  # Only show logo on interactive mode or if it's the first argument
  if [[ "$1" == "--logo" ]] || [[ -z "${GHPR_LOGO_SHOWN:-}" ]]; then
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    if [[ -f "$script_dir/ghpr-logo.sh" ]]; then
      bash "$script_dir/ghpr-logo.sh"
      export GHPR_LOGO_SHOWN=true
    fi
  fi
}

# ─── Pre-flight ───────────────────────────────────────────────────────────────

require_cmd git

git rev-parse --is-inside-work-tree &>/dev/null || die "Not inside a git repository."

# Check for ongoing merge or rebase
if [[ -d .git/MERGE_HEAD ]]; then
  die "A merge is in progress. Resolve conflicts and run: git commit"
elif [[ -d .git/rebase-merge ]] || [[ -d .git/rebase-apply ]]; then
  die "A rebase is in progress. Resolve conflicts and run: git rebase --continue"
fi

# Check for updates (non-blocking, run in background if possible)
check_for_updates &
disown 2>/dev/null || true

# Capture the branch we're on right now — this becomes the BASE default.
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
ORIGIN_HEAD=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)
DEFAULT_BASE_BRANCH="$CURRENT_BRANCH"
if [[ -n "$ORIGIN_HEAD" ]]; then
  DEFAULT_BASE_BRANCH="${ORIGIN_HEAD#origin/}"
fi

# ─── Defaults ─────────────────────────────────────────────────────────────────

HEAD_BRANCH="$CURRENT_BRANCH"
BASE_BRANCH="$DEFAULT_BASE_BRANCH"
COMMIT_MSG=""
DRAFT=false
SKIP_PR=false
DRY_RUN=false
JSON_OUTPUT=false
SHOW_PREVIEW=false
SUGGEST_MODE=false
INTERACTIVE_MODE=true
DEFAULT_BASE=""
PR_BODY=""
FILES=()

# ─── Argument Parsing ─────────────────────────────────────────────────────────

while [[ $# -gt 0 ]]; do
  case "$1" in
    -H|--head)
      [[ -n "${2-}" ]] || die "--head requires a branch name."
      HEAD_BRANCH="$2"; shift 2 ;;
    -b|--base)
      [[ -n "${2-}" ]] || die "--base requires a branch name."
      BASE_BRANCH="$2"; shift 2 ;;
    -m|--message)
      [[ -n "${2-}" ]] || die "--message requires a value."
      COMMIT_MSG="$2"; shift 2 ;;
    -d|--draft)
      DRAFT=true; shift ;;
    --no-pr)
      SKIP_PR=true; shift ;;
    --dry-run)
      DRY_RUN=true; shift ;;
    --json)
      JSON_OUTPUT=true; shift ;;
    -v|--version)
      print_version ;;
    -h|--help)
      usage ;;
    --preview)
      SHOW_PREVIEW=true; shift ;;
    --suggest)
      SUGGEST_MODE=true; shift ;;
    --agent)
      agent_mode_prompt ;;
    --status)
      status_report ;;
    --logo)
      show_logo_on_first_run --logo
      exit 0
      ;;
    --)
      shift; FILES+=("$@"); break ;;
    -*)
      die "Unknown option: $1  (run ghpr --help for usage)" ;;
    *)
      FILES+=("$1"); shift ;;
  esac
done

if [[ "$SKIP_PR" != true ]]; then
  require_cmd gh
  gh auth status &>/dev/null || die "GitHub CLI is not authenticated. Run: gh auth login"
fi

# ─── Load Config and Handle Special Modes ───────────────────────────────────────

load_config

# Handle suggest mode
if [[ "$SUGGEST_MODE" == true ]]; then
  git diff --cached --quiet && die "No staged changes to suggest from. Stage files first with 'git add'."
  suggestion=$(suggest_commit_message)
  if [[ "$JSON_OUTPUT" == true ]]; then
    output_json true "Suggestion: $suggestion"
  else
    echo ""
    echo "💡 Suggested message:"
    echo "   $suggestion"
    echo ""
  fi
  exit 0
fi

# Handle interactive mode (if no args and not in special modes)
if [[ -z "$COMMIT_MSG" && ${#FILES[@]} -eq 0 && "$SUGGEST_MODE" != true && "$DRY_RUN" != true ]]; then
  if [[ "$INTERACTIVE_MODE" == "true" ]]; then
    interactive_prompt
  fi
fi

# Handle preview mode
if [[ "$SHOW_PREVIEW" == true ]]; then
  show_diff_preview
fi

if [[ "$HEAD_BRANCH" != "$CURRENT_BRANCH" ]]; then
  if ! git diff --quiet || ! git diff --cached --quiet; then
    die "Cannot switch to $HEAD_BRANCH with local changes present. Commit or stash changes first."
  fi
  suppress_output || info "Switching to branch: $HEAD_BRANCH"
  if [[ "$DRY_RUN" != true ]]; then
    git checkout "$HEAD_BRANCH"
  fi
fi

# ─── Stage files ──────────────────────────────────────────────────────────────

if [[ ${#FILES[@]} -gt 0 ]]; then
  suppress_output || info "Staging: ${FILES[*]}"
  git add -- "${FILES[@]}"
else
  suppress_output || info "Staging all changes (git add -A)"
  git add -A
fi

# ─── Commit ───────────────────────────────────────────────────────────────────

if ! git diff --cached --quiet; then
  [[ -n "$COMMIT_MSG" ]] || die "A commit message is required (-m / --message) when there are staged changes."
  
  if [[ "$DRY_RUN" == true ]]; then
    suppress_output || info "[DRY RUN] Would commit: $COMMIT_MSG"
    COMMIT_HASH="dry-run-hash"
  else
    git commit -m "$COMMIT_MSG"
    COMMIT_HASH=$(git rev-parse --short HEAD)
    suppress_output || ok "Committed: $COMMIT_MSG"
  fi
else
  suppress_output || info "Nothing to commit — working tree is clean."
fi

# ─── Sync with remote ─────────────────────────────────────────────────────────

if [[ "$DRY_RUN" != true ]]; then
  if git ls-remote --exit-code --heads origin "$HEAD_BRANCH" &>/dev/null; then
    suppress_output || info "Rebasing $HEAD_BRANCH onto origin/$HEAD_BRANCH..."
    git pull --rebase origin "$HEAD_BRANCH" 2>/dev/null || true
  else
    suppress_output || info "Remote branch origin/$HEAD_BRANCH not found yet — skipping pre-push rebase."
  fi
fi

# ─── Push ─────────────────────────────────────────────────────────────────────

suppress_output || info "Pushing $HEAD_BRANCH to origin..."
if [[ "$DRY_RUN" == true ]]; then
  suppress_output || info "[DRY RUN] Would push $HEAD_BRANCH to origin"
  PUSHED_BRANCH="$HEAD_BRANCH"
elif git ls-remote --exit-code --heads origin "$HEAD_BRANCH" &>/dev/null; then
  git push origin "$HEAD_BRANCH"
  PUSHED_BRANCH="$HEAD_BRANCH"
else
  git push --set-upstream origin "$HEAD_BRANCH"
  PUSHED_BRANCH="$HEAD_BRANCH"
fi
suppress_output || ok "Pushed $HEAD_BRANCH"

# ─── Pull Request ─────────────────────────────────────────────────────────────

if [[ "$SKIP_PR" == true ]]; then
  suppress_output || info "Skipping PR creation (--no-pr)."
  
  if [[ "$JSON_OUTPUT" == true ]]; then
    output_json true "Commit and push completed (PR skipped)"
  fi
  exit 0
fi

if [[ "$HEAD_BRANCH" == "$BASE_BRANCH" ]]; then
  suppress_output || info "HEAD and BASE are the same branch ($HEAD_BRANCH) — skipping PR creation."
  
  if [[ "$JSON_OUTPUT" == true ]]; then
    output_json true "Same branch; PR skipped"
  fi
  exit 0
fi

if [[ "$DRY_RUN" == true ]]; then
  suppress_output || info "[DRY RUN] Would create PR: $HEAD_BRANCH → $BASE_BRANCH"
  suppress_output || info "[DRY RUN] Title: $COMMIT_MSG"
  PR_CREATED=true
  
  if [[ "$JSON_OUTPUT" == true ]]; then
    output_json true "Dry run completed successfully"
  fi
  exit 0
fi

OPEN_PRS=$(gh pr list \
  --base "$BASE_BRANCH" \
  --head "$HEAD_BRANCH" \
  --state open \
  --json number \
  --jq 'length')

if [[ "$OPEN_PRS" == "0" ]]; then
  DRAFT_FLAG=""
  [[ "$DRAFT" == true ]] && DRAFT_FLAG="--draft"

  # Prompt for PR body in interactive mode if not in JSON/dry-run mode
  if [[ "$INTERACTIVE_MODE" == true && "$JSON_OUTPUT" != true && "$DRY_RUN" != true ]]; then
    prompt_for_pr_body
  fi

  gh pr create \
    --base "$BASE_BRANCH" \
    --head "$HEAD_BRANCH" \
    --title "$COMMIT_MSG" \
    --body "${PR_BODY:-PR from $HEAD_BRANCH to $BASE_BRANCH}" \
    $DRAFT_FLAG

  suppress_output || ok "PR created: $HEAD_BRANCH → $BASE_BRANCH"
  PR_CREATED=true
else
  suppress_output || info "An open PR already exists for $HEAD_BRANCH → $BASE_BRANCH."
fi

if [[ "$JSON_OUTPUT" == true ]]; then
  output_json true "Operation completed successfully"
fi
